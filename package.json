{
  "name": "behind-the-song",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pretypecheck": "next typegen",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node db/migrate.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "pree2e": "npm run build",
    "e2e": "playwright test",
    "pree2e:headed": "npm run build",
    "e2e:headed": "playwright test --headed",
    "pree2e:manual": "npm run build",
    "e2e:manual": "MANUAL_E2E=1 playwright test e2e/manual-intervention.spec.ts --headed",
    "pree2e:spotify:auth": "npm run build && node scripts/spotify-auth-state.mjs restore",
    "e2e:spotify:auth": "LIVE_SPOTIFY_E2E=1 LIVE_SPOTIFY_INTERACTIVE=1 playwright test --project=live-auth-setup",
    "pree2e:spotify": "npm run build && node scripts/spotify-auth-state.mjs restore",
    "e2e:spotify": "LIVE_SPOTIFY_E2E=1 LIVE_SPOTIFY_INTERACTIVE=1 playwright test --project=live-spotify",
    "pree2e:spotify:interactive": "npm run build && node scripts/spotify-auth-state.mjs restore",
    "e2e:spotify:interactive": "LIVE_SPOTIFY_E2E=1 LIVE_SPOTIFY_INTERACTIVE=1 playwright test --project=live-spotify",
    "e2e:spotify:clear": "node scripts/spotify-auth-state.mjs clear",
    "smoke:remote": "node scripts/remote-smoke.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "@upstash/redis": "^1.35.6",
    "@vibrant/core": "^4.0.4",
    "@vibrant/generator-default": "^4.0.4",
    "@vibrant/image": "^4.0.4",
    "@vibrant/quantizer-mmcq": "^4.0.4",
    "dompurify": "^3.1.5",
    "iconoir-react": "^7.7.0",
    "jsdom": "^24.1.0",
    "lz-string": "^1.5.0",
    "next": "15.5.15",
    "openai": "^6.34.0",
    "postgres": "^3.4.7",
    "react": "^18.3.1",
    "react-dom": "^18",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.14",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8",
    "eslint-config-next": "15.5.15",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
